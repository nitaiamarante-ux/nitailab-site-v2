---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  updated?: string;
  tag: string;
  author?: string;
  faq?: Array<{ q: string; a: string }>;
}

const { title, description, date, updated, tag, author = "Nitai Amarante", faq = [] } = Astro.props;
const siteUrl = "https://nitailab.com.br";
const currentUrl = `${siteUrl}${Astro.url.pathname}`;
const isoDate = new Date(date).toISOString();
const isoUpdated = updated ? new Date(updated).toISOString() : isoDate;
const displayDate = new Date(date).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<Base title={title} description={description}>
  <Nav />

  <!-- Schema Article -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": isoDate,
    "dateModified": isoUpdated,
    "author": {
      "@type": "Person",
      "name": author,
      "jobTitle": "Fundador da Nitai Lab",
      "url": `${siteUrl}/sobre/`
    },
    "publisher": {
      "@type": "Organization",
      "name": "Nitai Lab",
      "url": siteUrl
    },
    "mainEntityOfPage": currentUrl,
    "articleSection": tag
  })} />

  <!-- Schema FAQ (se houver) -->
  {faq.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faq.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    })} />
  )}

  <article class="post">
    <div class="container container--sm">
      <header class="post__header reveal">
        <span class="eyebrow">{tag}</span>
        <h1>{title}</h1>
        <div class="post__meta">
          <span>{author}</span>
          <span class="post__dot"></span>
          <time datetime={date}>{displayDate}</time>
        </div>
      </header>

      <div class="post__body reveal">
        <slot />
      </div>

      {faq.length > 0 && (
        <section class="post__faq reveal">
          <h2>Perguntas frequentes</h2>
          {faq.map(f => (
            <details class="faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </section>
      )}

      <footer class="post__footer reveal">
        <div class="post__cta">
          <h3>Quer ajuda com isso na sua clínica?</h3>
          <p>Uma conversa de 15 minutos. Sem compromisso.</p>
          <a href="https://wa.me/551152865757?text=Olá,%20vim%20pelo%20blog%20e%20quero%20entender%20mais." class="btn btn--primary" target="_blank" rel="noopener">
            Agendar uma conversa
          </a>
        </div>
      </footer>
    </div>
  </article>

  <Footer />
</Base>

<style>
  .post {
    padding-top: calc(64px + var(--space-xl));
    padding-bottom: var(--space-xl);
  }

  .post__header {
    margin-bottom: var(--space-lg);
  }

  .post__header h1 {
    margin-top: 0.5rem;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.15;
  }

  .post__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--soft);
  }

  .post__dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--bdr);
  }

  .post__body {
    font-family: 'Outfit', sans-serif;
    font-size: 1.0625rem;
    font-weight: 300;
    line-height: 1.9;
    color: var(--mid);
  }

  .post__body :global(h2) {
    font-family: 'Urbanist', sans-serif;
    font-weight: 700;
    font-size: 1.375rem;
    color: var(--dark);
    margin: 2.5rem 0 0.75rem;
  }

  .post__body :global(h3) {
    font-family: 'Urbanist', sans-serif;
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--dark);
    margin: 2rem 0 0.5rem;
  }

  .post__body :global(p) {
    margin-bottom: 1.25rem;
  }

  .post__body :global(strong) {
    color: var(--dark);
    font-weight: 400;
  }

  .post__body :global(ul),
  .post__body :global(ol) {
    margin: 1rem 0 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post__body :global(blockquote) {
    border-left: 2px solid var(--gold);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--mid);
  }

  .post__faq {
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--bdr);
  }

  .post__faq h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .faq-item {
    border-bottom: 1px solid var(--bdr);
    padding: 1rem 0;
  }

  .faq-item summary {
    font-family: 'Urbanist', sans-serif;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    color: var(--dark);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary::after {
    content: '+';
    font-size: 1.125rem;
    color: var(--gold);
    transition: transform 0.3s;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    color: var(--mid);
    font-size: 0.9375rem;
    margin-top: 0.5rem;
    line-height: 1.7;
  }

  /* Imagens de blog */
  .post__body :global(.blog-img) {
    margin: 2rem -1rem;
    border-radius: 8px;
    overflow: hidden;
  }

  .post__body :global(.blog-img img) {
    width: 100%;
    display: block;
  }

  /* Comparativo GMN */
  .post__body :global(.gmn-compare) {
    display: flex;
    gap: 1rem;
    align-items: stretch;
    margin: 2rem 0;
    font-family: 'Outfit', sans-serif;
  }

  .post__body :global(.gmn-vs) {
    display: flex;
    align-items: center;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--bdr);
    flex-shrink: 0;
  }

  .post__body :global(.gmn-card) {
    flex: 1;
    border: 1px solid var(--bdr);
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    position: relative;
  }

  .post__body :global(.gmn-card h4) {
    font-family: 'Urbanist', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--dark);
    padding: 1rem 1rem 0;
    margin: 0;
  }

  .post__body :global(.gmn-badge) {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 0.625rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post__body :global(.gmn-badge--good) {
    background: #e6f4ea;
    color: #137333;
  }

  .post__body :global(.gmn-badge--bad) {
    background: #fce8e6;
    color: #c5221f;
  }

  .post__body :global(.gmn-cat) {
    font-size: 0.75rem;
    color: var(--soft);
    padding: 0 1rem;
    display: block;
  }

  .post__body :global(.gmn-stars) {
    font-size: 0.8125rem;
    color: #fbbc04;
    padding: 0.375rem 1rem;
  }

  .post__body :global(.gmn-stars span) {
    color: var(--mid);
    font-size: 0.75rem;
  }

  .post__body :global(.gmn-stars--low) {
    color: #dadce0;
  }

  .post__body :global(.gmn-photos) {
    display: flex;
    gap: 2px;
    padding: 0 2px;
  }

  .post__body :global(.gmn-photo) {
    flex: 1;
    height: 52px;
    border-radius: 3px;
    background: linear-gradient(135deg, #e8d5c4, #d4b896);
  }

  .post__body :global(.gmn-photo--empty) {
    background: #f1f3f4;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    color: #9aa0a6;
  }

  .post__body :global(.gmn-post) {
    padding: 0.75rem 1rem;
    border-top: 1px solid #f1f3f4;
  }

  .post__body :global(.gmn-post-label) {
    font-size: 0.625rem;
    font-weight: 600;
    color: #1a73e8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post__body :global(.gmn-post p) {
    font-size: 0.8125rem;
    color: var(--dark);
    margin: 0.25rem 0;
  }

  .post__body :global(.gmn-post-date) {
    font-size: 0.6875rem;
    color: #9aa0a6;
  }

  .post__body :global(.gmn-no-post) {
    padding: 1.25rem 1rem;
    text-align: center;
    font-size: 0.8125rem;
    color: #9aa0a6;
    border-top: 1px solid #f1f3f4;
  }

  .post__body :global(.gmn-no-post span) {
    font-size: 0.6875rem;
    color: #bdc1c6;
  }

  @media (max-width: 600px) {
    .post__body :global(.gmn-compare) {
      flex-direction: column;
    }
    .post__body :global(.gmn-vs) {
      justify-content: center;
    }
  }

  .post__footer {
    margin-top: var(--space-lg);
  }

  .post__cta {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--bg3);
    border-radius: 12px;
  }

  .post__cta h3 {
    margin-bottom: 0.5rem;
  }

  .post__cta p {
    color: var(--mid);
    margin-bottom: 1.5rem;
  }
</style>
