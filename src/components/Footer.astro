<style>
  .footer {
    border-top: 1px solid var(--bdr);
    padding: 3rem 0;
    background: var(--bg);
  }

  .footer__inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__logo-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--dark);
  }

  .footer__logo {
    width: 28px;
    height: 14px;
    color: var(--gold);
  }

  .footer__name {
    font-family: 'Urbanist', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
  }

  .footer__tagline {
    font-size: 0.8125rem;
    color: var(--soft);
  }

  .footer__nav {
    display: flex;
    gap: 1.5rem;
  }

  .footer__nav a {
    font-family: 'Urbanist', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--mid);
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer__nav a:hover {
    color: var(--dark);
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.375rem;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social a {
    color: var(--mid);
    transition: color 0.3s;
  }

  .footer__social a:hover {
    color: var(--dark);
  }

  .footer__contact a {
    font-size: 0.8125rem;
    color: var(--mid);
  }

  .footer__copy {
    font-size: 0.75rem;
    color: var(--soft);
  }

  /* WhatsApp float */
  .wa-float {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 200;
    width: 52px;
    height: 52px;
    background: var(--wa);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.35);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .wa-float:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(37, 211, 102, 0.45);
  }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer__contact {
      align-items: center;
    }

    .footer__nav {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
