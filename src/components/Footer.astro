---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      <a href={base} class="footer__logo-link">
        <svg class="footer__logo" viewBox="0 0 40 20" fill="none">
          <path d="M0 12 L8 12 L12 4 L16 16 L20 8 L24 12 L40 12" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="footer__name">NITAI LAB</span>
      </a>
      <p class="footer__tagline">Agenda cheia. De forma previsível.</p>
    </div>

    <nav class="footer__nav">
      <a href={base}>Home</a>
      <a href={`${base}sobre`}>Sobre</a>
      <a href={`${base}servicos`}>Serviços</a>
      <a href={`${base}blog`}>Blog</a>
    </nav>

    <div class="footer__contact">
      <a href="mailto:nitai@nitailab.com.br">nitai@nitailab.com.br</a>
      <span class="footer__copy">&copy; {year} Nitai Lab</span>
    </div>
  </div>
</footer>

<!-- WhatsApp flutuante -->
<a href="https://wa.me/551152865757?text=Olá,%20gostaria%20de%20saber%20mais%20sobre%20a%20Nitai%20Lab." class="wa-float" target="_blank" rel="noopener" aria-label="WhatsApp">
  <svg viewBox="0 0 24 24" fill="#fff" width="24" height="24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
</a>

<style>
  .footer {
    border-top: 1px solid var(--bdr);
    padding: 3rem 0;
    background: var(--bg);
  }

  .footer__inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__logo-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--dark);
  }

  .footer__logo {
    width: 28px;
    height: 14px;
    color: var(--gold);
  }

  .footer__name {
    font-family: 'Urbanist', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
  }

  .footer__tagline {
    font-size: 0.8125rem;
    color: var(--soft);
  }

  .footer__nav {
    display: flex;
    gap: 1.5rem;
  }

  .footer__nav a {
    font-family: 'Urbanist', sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--mid);
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer__nav a:hover {
    color: var(--dark);
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.375rem;
  }

  .footer__contact a {
    font-size: 0.8125rem;
    color: var(--mid);
  }

  .footer__copy {
    font-size: 0.75rem;
    color: var(--soft);
  }

  /* WhatsApp float */
  .wa-float {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 200;
    width: 52px;
    height: 52px;
    background: var(--wa);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(37, 211, 102, 0.35);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .wa-float:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(37, 211, 102, 0.45);
  }

  @media (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer__contact {
      align-items: center;
    }

    .footer__nav {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
