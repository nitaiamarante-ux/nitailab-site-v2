  }

  .rg-neglig__alert strong {
    font-weight: 600;
  }

  .rg-neglig__alert--blue,
  .rg-neglig__alert--yellow,
  .rg-neglig__alert--red {
    background: rgba(160, 120, 64, 0.08);
    color: var(--gold);
    stroke: var(--gold);
  }

  /* Highlight animado */
  .rg-hl {
    background: none;
    color: inherit;
    position: relative;
    display: inline;
    padding: 1px 4px;
    margin: 0 -4px;
    border-radius: 3px;
    background-size: 0% 100%;
    background-repeat: no-repeat;
    background-position: 0 0;
    transition: background-size 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.4s;
  }

  .rg-hl--blue,
  .rg-hl--yellow,
  .rg-hl--red { background-image: linear-gradient(120deg, rgba(160, 120, 64, 0.18) 0%, rgba(160, 120, 64, 0.18) 100%); }

  .visible .rg-hl {
    background-size: 100% 100%;
  }

  .rg-hl--blue,
  .rg-hl--yellow,
  .rg-hl--red { color: var(--gold); font-weight: 400; }

  .rg-neglig__frase {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  /* EYEBROW PIN (reutilizável) */
  .rg-eyebrow__pin {
    width: 16px;
    height: auto;
    display: inline-block;
    vertical-align: middle;
    margin-right: 6px;
    position: relative;
    top: -1px;
  }

  /* ENTREGA */
  .rg-entrega__h2 {
    margin-bottom: 48px;
  }

  .rg-entrega__setup,
  .rg-entrega__recorrente {
    border: 1px solid var(--bdr);
    border-left: 3px solid var(--gold);
    background: var(--bg);
    padding: 40px 36px;
    margin-bottom: 16px;
    border-radius: 0 8px 8px 0;
  }

  .rg-entrega__setup h3,
  .rg-entrega__recorrente h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .rg-entrega__tag {
    font-family: 'Urbanist', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid var(--gold);
    padding: 3px 10px;
    border-radius: 100px;
  }

  .rg-entrega__setup ul,
  .rg-entrega__recorrente ul {
    list-style: none;
    padding: 0;
  }

  .rg-entrega__setup li,
  .rg-entrega__recorrente li {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
    padding: 6px 0 6px 24px;
    position: relative;
  }

  .rg-entrega__setup li::before,
  .rg-entrega__recorrente li::before {
    content: '';
    position: absolute;
    left: 2px;
    top: 12px;
    width: 7px;
    height: 10px;
    background: var(--gold);
    clip-path: path('M3.5 0C1.57 0 0 1.57 0 3.5c0 2.63 3.5 6.5 3.5 6.5S7 6.13 7 3.5C7 1.57 5.43 0 3.5 0z');
    opacity: 0.7;
  }

  .rg-entrega__recorrente li strong {
    color: var(--dark);
    font-weight: 400;
  }

  /* CASE */
  .rg-case__h2 {
    margin-bottom: 48px;
  }

  .rg-case__body {
    border: 1px solid var(--bdr);
    background: var(--bg2);
  }

  .rg-case__stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 40px;
    padding: 48px 36px;
    border-bottom: 1px solid var(--bdr);
  }

  .rg-case__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .rg-case__num {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: 54px;
    letter-spacing: -0.03em;
    color: var(--mid);
    line-height: 1;
  }

  .rg-case__num sup {
    font-size: 22px;
    font-weight: 600;
  }

  .rg-case__num--gold {
    color: var(--gold);
  }

  .rg-case__of {
    font-size: 28px;
    font-weight: 400;
    color: var(--soft);
  }

  .rg-case__label {
    font-family: 'Urbanist', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--soft);
  }

  .rg-case__arrow {
    display: flex;
    align-items: center;
  }

  .rg-case__detail {
    padding: 40px 36px;
  }

  .rg-case__detail p {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
    margin-bottom: 12px;
  }

  .rg-case__detail p strong {
    color: var(--dark);
    font-weight: 400;
  }

  .rg-case__detail ul {
    list-style: none;
    padding: 0;
    margin-top: 8px;
  }

  .rg-case__detail li {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
    padding-left: 20px;
    position: relative;
  }

  .rg-case__detail li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--gold);
  }

  .rg-case__quote {
    margin-top: 40px;
    padding: 36px;
    border-left: 3px solid var(--gold);
    background: var(--bg2);
  }

  .rg-case__quote p {
    font-family: 'Outfit', sans-serif;
    font-size: 17px;
    font-weight: 300;
    font-style: italic;
    color: var(--dark);
    line-height: 1.7;
  }

  .rg-case__quote cite {
    display: block;
    margin-top: 16px;
    font-family: 'Urbanist', sans-serif;
    font-size: 12px;
    font-weight: 500;
    font-style: normal;
    letter-spacing: 0.04em;
    color: var(--soft);
  }

  .rg-case__testimonial {
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    text-align: center;
  }

  .rg-case__testimonial-label {
    font-family: 'Urbanist', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--soft);
    margin-bottom: 24px;
  }

  .rg-case__prints {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .rg-case__prints img {
    max-width: 320px;
    width: 100%;
    height: auto;
    border-radius: 14px;
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.12);
  }

  .rg-case__testimonial-cite {
    display: block;
    font-family: 'Urbanist', sans-serif;
    font-size: 12px;
    font-weight: 500;
    font-style: normal;
    letter-spacing: 0.04em;
    color: var(--soft);
  }

  @media (max-width: 640px) {
    .rg-case__prints {
      gap: 14px;
    }
    .rg-case__prints img {
      max-width: 100%;
    }
  }

  /* COMO FUNCIONA */
  .rg-como__h2 {
    margin-bottom: 48px;
  }

  .rg-como__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--bdr);
  }

  .rg-como__step {
    padding: 48px 32px;
    border-right: 1px solid var(--bdr);
    background: var(--bg);
  }

  .rg-como__step:last-child {
    border-right: none;
  }

  .rg-como__n {
    font-family: 'Urbanist', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: 24px;
    display: block;
  }

  .rg-como__step h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .rg-como__step p {
    font-size: 15px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
  }

  /* FAQ */
  .rg-faq__list {
    margin-top: 32px;
  }

  .rg-faq__item {
    border-bottom: 1px solid var(--bdr);
  }

  .rg-faq__item summary {
    font-family: 'Urbanist', sans-serif;
    font-size: 17px;
    font-weight: 600;
    color: var(--dark);
    padding: 20px 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .rg-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .rg-faq__item summary::after {
    content: '+';
    font-family: 'Urbanist', sans-serif;
    font-size: 24px;
    font-weight: 300;
    color: var(--gold);
    transition: transform 0.3s;
  }

  .rg-faq__item[open] summary::after {
    content: '−';
  }

  .rg-faq__item p {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
    padding: 0 0 20px;
    max-width: 600px;
  }

  /* GARANTIA */
  .rg-garantia__box {
    text-align: center;
    padding: 56px 40px;
    border: 1px solid var(--bdr);
    background: var(--bg);
  }

  .rg-garantia__badge {
    display: inline-block;
    font-family: 'Urbanist', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    border: 2px solid var(--gold);
    padding: 8px 20px;
    border-radius: 100px;
    margin-bottom: 24px;
  }

  .rg-garantia__box h3 {
    font-size: clamp(20px, 2.5vw, 28px);
    margin-bottom: 16px;
  }

  .rg-garantia__box p {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
    max-width: 520px;
    margin: 0 auto;
  }

  /* PREÇO */
  .rg-preco {
    padding: 80px 48px;
    background: var(--dark);
    text-align: center;
  }

  .rg-preco__inner {
    max-width: 480px;
    margin: 0 auto;
  }

  .rg-preco__inner .eyebrow {
    margin-bottom: 20px;
  }

  .rg-preco__valor {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 4px;
    margin-bottom: 12px;
  }

  .rg-preco__cifrao {
    font-family: 'Urbanist', sans-serif;
    font-size: 24px;
    font-weight: 600;
    color: var(--soft);
  }

  .rg-preco__num {
    font-family: 'Urbanist', sans-serif;
    font-size: clamp(64px, 10vw, 96px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--bg);
    line-height: 1;
  }

  .rg-preco__periodo {
    font-family: 'Urbanist', sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: var(--soft);
  }

  .rg-preco__detalhe {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 200;
    color: var(--soft);
    margin-bottom: 40px;
  }

  .rg-preco__cta {
    font-size: 0.9375rem;
    padding: 1rem 2.5rem;
  }

  .rg-preco__garantia {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: rgba(245, 240, 235, 0.3);
    margin-top: 16px;
  }

  /* URGÊNCIA */
  .rg-urgencia__inner {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .rg-urgencia__h2 {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: clamp(24px, 3.5vw, 46px);
    letter-spacing: -0.035em;
    line-height: 1.02;
    color: var(--dark);
    margin-bottom: 48px;
  }

  .rg-urgencia__h2 em {
    font-style: normal;
    color: var(--gold);
  }

  .rg-urgencia__cta {
    font-size: 0.9375rem;
    padding: 1rem 2.5rem;
  }

  .rg-urgencia__vagas {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: var(--soft);
    margin-top: 16px;
    letter-spacing: 0.02em;
  }

  /* HERO CTA2 (ghost button) */
  .rg-hero__cta2 {
    display: inline-block;
    margin-top: 12px;
    margin-left: 0;
    font-family: 'Urbanist', sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--soft);
    border: 1px solid rgba(245, 240, 235, 0.2);
    padding: 1rem 2.5rem;
    text-decoration: none;
    transition: border-color 0.3s, color 0.3s;
    opacity: 0;
    animation: rgUp 0.6s ease 0.85s forwards;
  }

  .rg-hero__cta2:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  /* MOCK CARD */
  .rg-mock__card {
    width: 100%;
    max-width: 380px;
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    font-family: 'Outfit', sans-serif;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(160, 120, 64, 0.15);
  }

  .rg-mock__header {
    padding: 12px 16px;
    background: #fff;
    border-bottom: 1px solid #e8eaed;
  }

  .rg-mock__searchbar {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #f1f3f4;
    border-radius: 24px;
    padding: 10px 16px;
    font-size: 13px;
    color: #5f6368;
  }

  .rg-mock__results {
    padding: 4px 0;
  }

  .rg-mock__item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 16px;
    border-bottom: 1px solid #f1f3f4;
  }

  .rg-mock__item:last-child {
    border-bottom: none;
  }

  .rg-mock__rank {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: #e8eaed;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: #5f6368;
    margin-top: 2px;
  }

  .rg-mock__rank--you {
    width: 34px;
    height: 34px;
    background: #e8eaed;
    color: #5f6368;
    font-size: 12px;
    animation: rgPulse 2.5s ease-in-out 1.5s infinite;
  }

  .rg-mock__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .rg-mock__name {
    font-size: 14px;
    font-weight: 500;
    color: #202124;
  }

  .rg-mock__name--you {
    color: #202124;
    font-weight: 700;
    font-size: 15px;
  }

  .rg-mock__stars {
    font-size: 13px;
    color: #fbbc04;
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .rg-mock__stars--empty {
    color: #dadce0;
  }

  .rg-mock__count {
    font-size: 12px;
    color: #9aa0a6;
    margin-left: 2px;
  }

  .rg-mock__detail {
    font-size: 12px;
    color: #70757a;
    font-weight: 300;
  }

  .rg-mock__detail--warn {
    color: #ea4335;
    font-weight: 500;
  }

  .rg-mock__star--dim {
    color: #fbbc04;
    opacity: 0.45;
  }

  .rg-mock__item--you {
    background: #fff;
    border-left: 3px solid var(--gold);
  }

  /* SKIP — "muitas clínicas na frente" */
  .rg-mock__skip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 14px 16px;
    font-size: 12px;
    background: #f8f8f8;
    color: #9aa0a6;
    border-bottom: 1px solid #f1f3f4;
  }

  .rg-mock__skip span {
    color: #dadce0;
  }

  .rg-mock__skip-txt {
    color: #202124;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .rg-mock__caption {
    text-align: center;
    padding: 14px 16px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: #ea4335;
    background: #fef7f6;
    border-top: 1px solid #fce8e6;
    max-width: 100%;
  }

  /* ÍCONES DOURADO PADRÃO */
  .rg-neglig__icon--blue,
  .rg-neglig__icon--yellow,
  .rg-neglig__icon--red {
    color: var(--gold);
    border-color: rgba(160, 120, 64, 0.3);
  }

  /* SOCIAL PROOF BAR — Google metrics style */
  .rg-proof {
    background: var(--bg2);
    border-top: 1px solid var(--bdr);
    border-bottom: 1px solid var(--bdr);
    padding: 36px 48px;
  }

  .rg-proof__inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 36px;
  }

  .rg-proof__item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .rg-proof__icon {
    flex-shrink: 0;
  }

  .rg-proof__num {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: 36px;
    letter-spacing: -0.03em;
    color: var(--dark);
    line-height: 1;
  }

  .rg-proof__of {
    font-size: 18px;
    font-weight: 400;
    color: var(--soft);
  }

  .rg-proof__label {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.4;
    max-width: 120px;
  }

  .rg-proof__sep {
    width: 1px;
    height: 36px;
    background: var(--bdr);
  }

  /* PREÇO COMPARATIVO */
  .rg-preco__comparativo {
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: rgba(245, 240, 235, 0.25);
    margin-top: 20px;
    margin-bottom: 0;
    letter-spacing: 0.01em;
  }

  /* DIAGNÓSTICO GRATUITO */
  .rg-diagnostico {
    background: var(--bg2);
  }

  .rg-diagnostico__box {
    text-align: center;
    padding: 64px 40px;
    border: 2px solid var(--gold);
    background: var(--bg);
    border-radius: 8px;
  }

  .rg-diagnostico__h2 {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: clamp(22px, 3vw, 36px);
    letter-spacing: -0.03em;
    color: var(--dark);
    margin-top: 16px;
    margin-bottom: 12px;
  }

  .rg-diagnostico__sub {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
    margin: 0 auto 32px;
  }

  .rg-diagnostico__form {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    max-width: 440px;
    margin: 0 auto;
  }

  .rg-diagnostico__input {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: var(--dark);
    background: rgba(245, 240, 235, 0.95);
    border: 1px solid rgba(160, 120, 64, 0.2);
    border-radius: 8px;
    padding: 14px 18px;
    outline: none;
    transition: border-color 0.2s;
    flex: 1;
    min-width: 0;
  }

  .rg-diagnostico__input:focus {
    border-color: var(--gold);
    background: #fff;
  }

  .rg-diagnostico__input::placeholder {
    color: var(--soft);
    font-weight: 300;
  }

  .rg-diagnostico__cta {
    flex-shrink: 0;
    white-space: nowrap;
  }

  .rg-diagnostico__ok {
    padding: 20px 0 0;
  }

  .rg-diagnostico__ok p {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: var(--mid);
    margin-top: 12px;
  }

  @media (max-width: 560px) {
    .rg-diagnostico__form {
      flex-direction: column;
    }

    .rg-diagnostico__input {
      width: 100%;
    }

    .rg-diagnostico__cta {
      width: 100%;
      justify-content: center;
    }

    .rg-diagnostico__box {
      padding: 48px 24px;
    }
  }

  /* AUDITORIA GRÁTIS */
  .rg-auditoria__box {
    text-align: center;
    padding: 64px 40px;
    border: 2px solid var(--gold);
    background: var(--bg);
  }

  .rg-auditoria__h2 {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: clamp(22px, 3vw, 36px);
    letter-spacing: -0.03em;
    color: var(--dark);
    margin-top: 16px;
    margin-bottom: 16px;
  }

  .rg-auditoria__sub {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.8;
    max-width: 480px;
    margin: 0 auto 32px;
  }

  .rg-auditoria__cta {
    font-size: 0.9375rem;
    padding: 1rem 2.5rem;
  }

  /* CTA INTERMEDIÁRIOS */
  .rg-cta-mid {
