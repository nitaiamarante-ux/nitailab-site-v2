  .rg-neglig__card--blue .rg-neglig__badge { background: var(--gold); color: #fff; }
  .rg-neglig__card--yellow .rg-neglig__badge { background: var(--gold); color: #fff; }
  .rg-neglig__card--red .rg-neglig__badge { background: var(--gold); color: #fff; }

  .rg-neglig__card h3 {
    font-size: 18px;
    font-weight: 700;
    color: #202124;
    margin-bottom: 10px;
  }

  .rg-neglig__card p {
    font-size: 15px;
    font-weight: 300;
    color: #5f6368;
    line-height: 1.7;
  }

  .rg-neglig__alert {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 18px;
    padding: 14px 16px;
    border-radius: 8px;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 300;
    line-height: 1.5;
  }

  .rg-neglig__alert svg {
    flex-shrink: 0;
