<style>

  /* HERO */
  .rg-hero {
    min-height: 100svh;
    padding-top: 64px;
    background: var(--dark);
    position: relative;
    overflow: hidden;
  }

  .rg-hero__mapgrid {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.04;
    background-image:
      linear-gradient(var(--gold) 1px, transparent 1px),
      linear-gradient(90deg, var(--gold) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at 60% 50%, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 60% 50%, black 0%, transparent 70%);
    pointer-events: none;
  }

  .rg-hero__layout {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    min-height: calc(100svh - 64px);
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 48px;
    gap: 48px;
  }

  .rg-hero__inner {
    padding: 60px 0;
  }

  .rg-hero__pinblock {
    margin-bottom: 20px;
    opacity: 0;
    animation: rgPinDrop 0.6s ease 0.2s both;
  }

  .rg-hero__pin {
    display: block;
    width: 44px;
    height: auto;
    filter: drop-shadow(0 4px 16px rgba(160, 120, 64, 0.5));
  }

  .rg-hero__inner .eyebrow {
    margin-bottom: 28px;
    opacity: 0;
    animation: rgUp 0.5s ease 0.15s forwards;
  }

  .rg-hero__h1 {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: clamp(32px, 4.5vw, 58px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--bg);
    opacity: 0;
    animation: rgUp 0.7s ease 0.3s forwards;
  }

  .rg-hero__h1 em {
    font-style: normal;
    color: var(--gold);
    display: block;
    margin-top: 0.12em;
  }

  .rg-hero__sub {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(15px, 1.3vw, 17px);
    font-weight: 200;
    line-height: 1.7;
    color: var(--soft);
    margin-top: 28px;
    max-width: 440px;
    opacity: 0;
    animation: rgUp 0.6s ease 0.5s forwards;
  }

  .rg-hero__cta {
    margin-top: 36px;
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 1rem 2.5rem;
    background: var(--gold);
    color: #fff;
    border: none;
    letter-spacing: 0.02em;
    opacity: 0;
    animation: rgUp 0.6s ease 0.7s forwards, rgPulse 2.5s ease-in-out 2s infinite;
    box-shadow: 0 0 0 0 rgba(160, 120, 64, 0.4);
  }

  /* MOCK DENTRO DO HERO */
  .rg-hero__mock {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 0;
    opacity: 0;
    animation: rgUp 0.8s ease 0.6s forwards;
  }

  /* PROBLEMA */
  .rg-problema {
    padding: 100px 48px;
    background: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rg-problema__inner {
    max-width: 780px;
    text-align: center;
  }

  .rg-problema__a {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: clamp(24px, 3.5vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--bg);
    display: block;
  }

  .rg-problema__search {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin: 32px 0;
    padding: 14px 28px;
    background: rgba(245, 240, 235, 0.06);
    border: 1px solid rgba(160, 120, 64, 0.25);
    border-radius: 100px;
    font-family: 'Outfit', sans-serif;
    font-size: clamp(16px, 1.6vw, 22px);
    font-weight: 300;
    color: var(--bg);
    letter-spacing: 0.01em;
  }

  .rg-problema__cursor {
    display: inline-block;
    width: 2px;
    height: 1.2em;
    background: var(--gold);
    animation: rgBlink 1s step-end infinite;
