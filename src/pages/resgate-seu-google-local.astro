<script>
  (function() {
    const STORAGE_KEY = 'rg_popup_shown';

    const popup = document.getElementById('exitPopup');
    const overlay = document.getElementById('exitOverlay');
    const closeBtn = document.getElementById('exitClose');
    const skipBtn = document.getElementById('exitSkip');
    if (!popup) return;

    let shown = false;

    function show() {
      if (shown) return;
      shown = true;
      popup.classList.add('active');
      popup.setAttribute('aria-hidden', 'false');
      sessionStorage.setItem(STORAGE_KEY, '1');
    }

    function hide() {
      popup.classList.remove('active');
      popup.setAttribute('aria-hidden', 'true');
    }

    if (sessionStorage.getItem(STORAGE_KEY)) return;
    {

      // Desktop: mouse sai pela parte de cima
      document.addEventListener('mouseout', function(e) {
        if (e.clientY < 5 && !e.relatedTarget && !e.toElement) {
          show();
        }
      });

      // Mobile: scroll reverso + tempo mínimo
      var isMobile = 'ontouchstart' in window || window.innerWidth < 768;
      if (isMobile) {
        var lastY = 0;
        var upCount = 0;
        var minTime = Date.now() + 15000; // 15s mínimo na página
        var minDepth = false;

        // Marca quando passou de 30% da página
        window.addEventListener('scroll', function() {
          var pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
          if (pct > 0.3) minDepth = true;
        }, { passive: true });

        // Detecta scroll reverso (subindo)
        window.addEventListener('scroll', function() {
          var y = window.scrollY;
          if (y < lastY) {
            upCount++;
          } else {
            upCount = 0;
          }
          lastY = y;

          // Dispara: já passou 30%, já ficou 15s, e scrollou pra cima 3+ vezes seguidas
          if (minDepth && Date.now() > minTime && upCount >= 3) {
            show();
          }
        }, { passive: true });

        // Fallback: 30s + 40% de scroll (se não scrollou pra cima)
        setTimeout(function() {
          var check = function() {
            var pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
            if (pct > 0.4) {
              show();
            } else {
              window.addEventListener('scroll', function onFallback() {
                var p = window.scrollY / (document.body.scrollHeight - window.innerHeight);
                if (p > 0.4) {
                  show();
                  window.removeEventListener('scroll', onFallback);
                }
              }, { passive: true });
            }
          };
          check();
        }, 30000);
      }
    }

    closeBtn.addEventListener('click', hide);
    skipBtn.addEventListener('click', hide);

    // Popup 1 → Popup 2
    var exitCta = document.getElementById('exitCta');
    var formPopup = document.getElementById('formPopup');
    var formOverlay = document.getElementById('formOverlay');
    var formClose = document.getElementById('formClose');

    function showForm() {
      hide();
      setTimeout(function() {
        formPopup.classList.add('active');
        formPopup.setAttribute('aria-hidden', 'false');
      }, 300);
    }

    function hideForm() {
      formPopup.classList.remove('active');
      formPopup.setAttribute('aria-hidden', 'true');
    }

    if (exitCta) exitCta.addEventListener('click', showForm);
    // overlay não fecha — só X e botões
    if (formClose) formClose.addEventListener('click', hideForm);

    // Form submit
    var form = document.getElementById('exitForm');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var data = {
          nome: form.nome.value,
          whatsapp: form.whatsapp.value,
          email: form.email.value,
          timestamp: new Date().toISOString(),
          source: 'exit_popup'
        };

        var leads = JSON.parse(localStorage.getItem('rg_leads') || '[]');
        leads.push(data);
        localStorage.setItem('rg_leads', JSON.stringify(leads));

        // Enviar pra Cloudflare Worker
        fetch('https://nitailab-hub.nitailab.workers.dev/leads', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: data.nome,
            email: data.email,
            phone: data.whatsapp,
            source: 'resgate-google-popup',
            page: window.location.href
          })
        }).catch(function() {});

        var box = formPopup.querySelector('.rg-popup__box');
        box.innerHTML = '<div style="padding:20px 0;text-align:center;">' +
          '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>' +
          '<h3 style="font-family:Urbanist,sans-serif;font-size:22px;font-weight:800;color:var(--dark);margin:20px 0 8px;">Recebido!</h3>' +
          '<p style="font-family:Outfit,sans-serif;font-size:15px;color:var(--mid);font-weight:300;">Vamos analisar seu perfil e te chamar no WhatsApp.</p>' +
          '</div>';
        setTimeout(hideForm, 3000);
      });
    }
  })();
</script>

<script>
  // Diagnosis form handler
  (function() {
    var diagForm = document.getElementById('diagForm');
    var diagOk = document.getElementById('diagOk');
    if (!diagForm) return;

    diagForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var whatsapp = diagForm.whatsapp.value;

      // Fire Meta Pixel Lead event
      if (typeof fbq === 'function') {
        fbq('track', 'Lead', {
          content_name: 'Resgate seu Google - Diagnostico',
          content_category: 'GMN'
        });
      }

      // POST to CF Worker
      fetch('https://nitailab-hub.nitailab.workers.dev/leads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          phone: whatsapp,
          source: 'resgate-google-diagnostico',
          page: window.location.href,
          timestamp: new Date().toISOString()
        })
      }).catch(function() {});

      // Save locally
      var leads = JSON.parse(localStorage.getItem('rg_leads') || '[]');
      leads.push({ whatsapp: whatsapp, source: 'diagnostico', timestamp: new Date().toISOString() });
      localStorage.setItem('rg_leads', JSON.stringify(leads));

      // Show confirmation
      diagForm.style.display = 'none';
      diagOk.style.display = 'block';
    });
  })();
</script>

<script is:inline>
  // Meta Pixel — track checkout clicks
  document.addEventListener('click', function(e) {
    var link = e.target.closest('a[href*="pay.hotmart.com"]');
    if (link && typeof fbq === 'function') {
      fbq('track', 'InitiateCheckout', {
        content_name: 'Resgate seu Google',
        content_category: 'GMN',
        value: 197.00,
        currency: 'BRL'
      });
    }
  });
  // Track lead capture popup submission
  document.addEventListener('submit', function(e) {
    if (e.target.closest('.rg-popup__form') && typeof fbq === 'function') {
      fbq('track', 'Lead', {
        content_name: 'Resgate seu Google - Popup',
        content_category: 'GMN'
      });
    }
  }, true);

  // === INTELIGÊNCIA DE COMPORTAMENTO ===
  (function() {
    var maxScroll = 0;
    var scrollMilestones = {25: false, 50: false, 75: false, 100: false};
    var startTime = Date.now();
    var engaged = false;

    // Scroll depth tracking
    window.addEventListener('scroll', function() {
      var scrollTop = window.scrollY || document.documentElement.scrollTop;
      var docHeight = document.documentElement.scrollHeight - window.innerHeight;
      var pct = Math.round((scrollTop / docHeight) * 100);
      if (pct > maxScroll) maxScroll = pct;

      for (var milestone in scrollMilestones) {
        if (!scrollMilestones[milestone] && pct >= parseInt(milestone)) {
          scrollMilestones[milestone] = true;
          if (typeof gtag === 'function') {
            gtag('event', 'scroll_depth', { percent: milestone, page: 'resgate-google' });
          }
          if (parseInt(milestone) >= 75 && typeof fbq === 'function' && !engaged) {
            fbq('trackCustom', 'HighEngagement', { scroll: milestone, time_on_page: Math.round((Date.now() - startTime) / 1000) });
            engaged = true;
          }
        }
      }
    });

    // Time on page tracking (30s, 60s, 120s)
    var timeMarkers = [30, 60, 120];
    timeMarkers.forEach(function(sec) {
      setTimeout(function() {
        if (typeof gtag === 'function') {
          gtag('event', 'time_on_page', { seconds: sec, page: 'resgate-google' });
        }
      }, sec * 1000);
    });

    // Track which sections are viewed (Intersection Observer)
    if ('IntersectionObserver' in window) {
      var sections = document.querySelectorAll('section[class*="rg-"]');
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var name = entry.target.className.match(/rg-[\w-]+/);
            if (name && typeof gtag === 'function') {
              gtag('event', 'section_view', { section: name[0], page: 'resgate-google' });
            }
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.5 });
      sections.forEach(function(s) { observer.observe(s); });
    }

    // Track exit intent (mouse leaves viewport)
    document.addEventListener('mouseout', function(e) {
      if (e.clientY < 5 && typeof gtag === 'function') {
        gtag('event', 'exit_intent', { scroll_depth: maxScroll, time: Math.round((Date.now() - startTime) / 1000) });
        document.removeEventListener('mouseout', arguments.callee);
      }
    });
  })();
</script>
