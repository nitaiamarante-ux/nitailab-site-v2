---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Base title="Agenda cheia para clínicas de estética">
  <Nav />

  <!-- CENA 1 — HERO -->
  <section class="hero">
    <img src={`${base}img/nitai-hero-v2.png`} alt="" class="hero__bg" />
    <div class="hero__body">
      <p class="eyebrow hero__eyebrow">Exclusivo para clínicas de estética</p>
      <h1 class="hero__h1">Agenda cheia não<br />vem de indicação.<br /><em>Vem de método.</em></h1>
    </div>
    <div class="hero__hint">
      <span>Role</span>
      <div class="hero__hint-line"></div>
    </div>
  </section>

  <!-- CENA 2 — FRASE -->
  <section class="frase">
    <div class="frase__wrap reveal">
      <span class="frase__a">Sua agenda não está vazia<br />porque seu trabalho não é bom o suficiente.</span>
      <span class="frase__b">Está vazia porque a estrutura certa<br />ainda não está <em>trabalhando por você.</em></span>
    </div>
  </section>

  <!-- CENA 3 — AMBIENTE -->
  <section class="ambiente">
    <img src={`${base}img/ambiente.png`} alt="" />
    <div class="ambiente__copy">
      <p>O problema não foi<br />o anúncio.<br /><em>Foi o que veio depois.</em></p>
    </div>
  </section>

  <!-- CENA 4 — MÉTODO -->
  <section class="metodo" id="metodo">
    <div class="metodo__inner">
      <div class="metodo__label reveal">
        <span class="eyebrow">O método</span>
      </div>
      <div class="metodo__grid">
        <div class="m-card reveal">
          <span class="m-n">01</span>
          <h3>Diagnóstico</h3>
          <p>Antes de sugerir qualquer coisa, já analisamos seu Instagram, Google Meu Negócio e qual é o seu perfil regulatório. A conversa começa no ponto certo — não do zero.</p>
        </div>
        <div class="m-card reveal">
          <span class="m-n">02</span>
          <h3>Estrutura</h3>
          <p>Anúncio para estética tem regras que vão além de saber criar campanha. Linguagem de antes/depois bloqueia conta. Promessa de resultado viola o CFM. Montamos tudo dentro do que é permitido — e que converte paciente de verdade.</p>
        </div>
        <div class="m-card reveal">
          <span class="m-n">03</span>
          <h3>Resultado</h3>
          <p>Você não recebe relatório. Você recebe um número: quanto custou cada paciente novo que entrou. Todo mês. Porque sem esse número, não tem como saber se a clínica está crescendo ou apenas movimentada.</p>
        </div>
      </div>
      <div class="metodo__cta reveal">
        <a href={`${base}servicos`} class="link-arrow">
          Ver os serviços
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2.5 7h9M8 3.5l3.5 3.5L8 10.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CENA 5 — NITAI -->
  <section class="nitai">
    <div class="nitai__foto">
      <img src={`${base}img/nitai-casual.png`} alt="Nitai — fundador" />
      <div class="nitai__tag">
        <span>Nitai · Fundador</span>
      </div>
    </div>
    <div class="nitai__texto reveal">
      <span class="eyebrow" style="margin-bottom:22px;display:block">Quem está por trás</span>
      <h2 class="nitai__h2">16 anos operando.<br />Uma escolha de nicho<br />que não foi por acaso.</h2>
      <p class="nitai__p">Passou <strong>16 anos liderando operações e equipes</strong> em uma das maiores empresas do Brasil. Aprendeu na prática o que separa negócio que cresce de negócio que depende de circunstância.</p>
      <p class="nitai__p">Quando decidiu empreender, escolheu um nicho com critério — e decidiu ficar nele. <strong>Só clínicas de estética.</strong></p>
      <div class="nitai__rule"></div>
      <p class="nitai__cite">Especialidade não é slogan. É o que aparece quando o anúncio é bloqueado, as regras mudam ou a campanha não converte.</p>
    </div>
  </section>

  <!-- CENA 6 — CTA FINAL -->
  <section class="fim">
    <div class="fim__inner reveal">
      <h2 class="fim__h2">Cada mês com agenda<br />vazia tem um custo.</h2>
      <a href="https://wa.me/551152865757?text=Olá,%20vim%20pelo%20site%20e%20quero%20agendar%20uma%20conversa." class="fim__btn" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.122 1.528 5.858L0 24l6.317-1.507A11.954 11.954 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.007-1.374l-.36-.213-3.727.889.918-3.621-.234-.373A9.784 9.784 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
        Agendar uma conversa
      </a>
      <p class="fim__sub">Vagas restritas · Por decisão</p>
    </div>
  </section>

  <Footer />
</Base>

<style>
  /* CENA 1 — HERO */
  .hero {
    height: 100svh;
    min-height: 600px;
    position: relative;
    overflow: hidden;
    padding-top: 64px;
    background: var(--dark);
  }

  .hero__bg {
    position: absolute;
    right: 0;
    bottom: 0;
    height: 100%;
    width: auto;
    max-width: 55%;
    object-fit: contain;
    object-position: right bottom;
    opacity: 0.35;
    z-index: 1;
    mask-image: linear-gradient(to left, rgba(0,0,0,0.6) 0%, transparent 85%);
    -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,0.6) 0%, transparent 85%);
    pointer-events: none;
  }

  .hero__body {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 48px;
    max-width: 720px;
  }

  .hero__eyebrow {
    margin-bottom: 28px;
    opacity: 0;
    animation: up 0.5s ease 0.15s forwards;
  }

  .hero__h1 {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: clamp(34px, 4.8vw, 68px);
    line-height: 0.93;
    letter-spacing: -0.04em;
    color: var(--bg);
    opacity: 0;
    animation: up 0.7s ease 0.3s forwards;
  }

  .hero__h1 em {
    font-style: normal;
    color: var(--gold);
    display: block;
    margin-top: 0.08em;
  }

  .hero__hint {
    position: absolute;
    bottom: 36px;
    left: 48px;
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    animation: up 0.5s ease 1.2s forwards;
  }

  .hero__hint span {
    font-family: 'Urbanist', sans-serif;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(245, 240, 235, 0.3);
  }

  .hero__hint-line {
    width: 36px;
    height: 1px;
    background: rgba(245, 240, 235, 0.15);
    overflow: hidden;
    position: relative;
  }

  .hero__hint-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: rgba(245, 240, 235, 0.5);
    animation: scan 2.5s ease-in-out infinite;
  }

  /* CENA 2 — FRASE */
  .frase {
    padding: 140px 48px;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .frase__wrap {
    max-width: 860px;
    text-align: center;
  }

  .frase__a {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: clamp(26px, 3.8vw, 54px);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--dark);
    display: block;
  }

  .frase__b {
    font-family: 'Urbanist', sans-serif;
    font-weight: 300;
    font-size: clamp(18px, 2vw, 30px);
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--mid);
    display: block;
    margin-top: 20px;
  }

  .frase__b em {
    font-style: normal;
    color: var(--gold);
  }

  /* CENA 3 — AMBIENTE */
  .ambiente {
    height: 68vh;
    min-height: 380px;
    position: relative;
    overflow: hidden;
  }

  .ambiente img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .ambiente::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(150deg, rgba(26,24,20,.65) 0%, rgba(26,24,20,.15) 55%, transparent 100%);
  }

  .ambiente__copy {
    position: absolute;
    z-index: 2;
    bottom: 52px;
    left: 52px;
    max-width: 520px;
  }

  .ambiente__copy p {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: clamp(20px, 3vw, 44px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--bg);
  }

  .ambiente__copy p em {
    font-style: normal;
    color: var(--goldL);
  }

  /* CENA 4 — MÉTODO */
  .metodo {
    padding: 120px 48px;
    max-width: 1080px;
    margin: 0 auto;
  }

  .metodo__label {
    margin-bottom: 64px;
  }

  .metodo__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--bdr);
    margin-bottom: 56px;
  }

  .m-card {
    padding: 52px 36px 48px;
    border-right: 1px solid var(--bdr);
    transition: background 0.25s;
  }

  .m-card:last-child {
    border-right: none;
  }

  .m-card:hover {
    background: var(--bg2);
  }

  .m-n {
    font-family: 'Urbanist', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: 28px;
    display: block;
  }

  .m-card h3 {
    font-family: 'Urbanist', sans-serif;
    font-size: 19px;
    font-weight: 800;
    color: var(--dark);
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .m-card p {
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 300;
    color: var(--mid);
    line-height: 1.85;
  }

  .metodo__cta {
    text-align: center;
  }

  /* CENA 5 — NITAI */
  .nitai {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }

  .nitai__foto {
    position: relative;
    overflow: hidden;
    background: var(--bg3);
  }

  .nitai__foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 45% top;
    display: block;
  }

  .nitai__tag {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 28px 36px;
    background: linear-gradient(to top, rgba(26,24,20,.45), transparent);
  }

  .nitai__tag span {
    font-family: 'Urbanist', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245, 240, 235, 0.55);
  }

  .nitai__texto {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 68px;
    background: var(--bg3);
  }

  .nitai__h2 {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: clamp(20px, 2.3vw, 34px);
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--dark);
    margin-bottom: 28px;
  }

  .nitai__p {
    font-family: 'Outfit', sans-serif;
    font-size: 16px;
    font-weight: 200;
    line-height: 1.9;
    color: var(--mid);
    margin-bottom: 16px;
  }

  .nitai__p strong {
    color: var(--dark);
    font-weight: 400;
  }

  .nitai__rule {
    width: 36px;
    height: 2px;
    background: var(--gold);
    margin: 28px 0;
  }

  .nitai__cite {
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 300;
    font-style: italic;
    line-height: 1.8;
    color: var(--mid);
  }

  /* CENA 6 — FIM */
  .fim {
    padding: 160px 48px;
    text-align: center;
    background: var(--bg);
  }

  .fim__inner {
    max-width: 520px;
    margin: 0 auto;
  }

  .fim__h2 {
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: clamp(26px, 3.8vw, 50px);
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--dark);
    margin-bottom: 48px;
  }

  .fim__btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Urbanist', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--dark);
    padding: 18px 44px;
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .fim__btn:hover {
    background: #2E2A26;
    color: var(--bg);
    transform: translateY(-2px);
    box-shadow: 0 14px 36px rgba(26, 24, 20, 0.15);
  }

  .fim__sub {
    margin-top: 16px;
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    font-weight: 300;
    color: var(--soft);
    letter-spacing: 0.04em;
  }

  /* ANIMAÇÕES */
  @keyframes up {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes scan {
    0% { left: -100%; }
    100% { left: 200%; }
  }

  /* RESPONSIVE */
  @media (max-width: 960px) {
    .hero__body {
      padding: 0 24px;
    }

    .hero__hint {
      left: 24px;
    }

    .frase {
      padding: 80px 24px;
    }

    .ambiente {
      height: 52vw;
      min-height: 240px;
    }

    .ambiente__copy {
      bottom: 28px;
      left: 28px;
    }

    .metodo {
      padding: 80px 24px;
    }

    .metodo__grid {
      grid-template-columns: 1fr;
    }

    .m-card {
      border-right: none;
      border-bottom: 1px solid var(--bdr);
    }

    .m-card:last-child {
      border-bottom: none;
    }

    .nitai {
      grid-template-columns: 1fr;
    }

    .nitai__foto {
      height: 65vw;
      min-height: 280px;
    }

    .nitai__texto {
      padding: 52px 24px;
    }

    .fim {
      padding: 100px 24px;
    }
  }

  @media (max-width: 560px) {
    .hero__h1 {
      font-size: 32px;
    }

    .frase__a {
      font-size: 24px;
    }

    .fim__h2 {
      font-size: 24px;
    }
  }
</style>
